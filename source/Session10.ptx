<!--START TYPING CONTENT FOR SESSION BELOW HERE-->
<worksheet>
    <title> Session #10 (Sections not sure)</title><!-- SECTION 10-->
    <p>
      Directions: Answer each of the following as best you can. Feel free to discuss your thoughts about the questions with some peers around you. 
      For additional practice problems and explanations, refer to the Math 152 textbook which can be found in your WebAssign Course.
    </p>
    <page>
      <paragraphs>
        <title>Getting Warmed Up and Focused</title>
      </paragraphs>
      <p>For #1-8 below, read the statement and then fill in the blank with "T" if the statement is true and "F" if the statement is false.</p>
    <exercise>
      <statement><!-- #1 -->
        <p>
         <m>\underline{\qquad\qquad\qquad}</m>The path represented by the parametric equations 
         <m>x(t)=\cos(t), \ y(t)=\sin(t)</m>, where <m>\displaystyle 0\leq t \leq \frac{3\pi}{2}</m>, is a circle 
         of radius 1, with initial point at <m>(1,0) </m>, terminal point at <m>(0,-1)</m>, and the path follows a counterclockwise direction.
        </p>
      </statement>
      </exercise>

      <exercise>
      <statement><!-- #2 -->
        <p>
        <m>\underline{\qquad\qquad\qquad}</m> The path represented by the parametric equations <m>x(t)=\sin(t), \ y(t)=\cos(t)</m>, where 
        <m>\displaystyle 0\leq t \leq \frac{3\pi}{2}</m>, is a circle of radius 1, with initial point at <m>(0,1)</m>, terminal point at <m>(-1,0)</m>, 
        and the path follows a clockwise direction.
        </p>
      </statement>
    </exercise>

    <exercise>
      <statement><!-- #3 -->
        <p> 
        <m>\underline{\qquad\qquad\qquad}</m> The paths represented by <m>x_1(t)=\sin(t), \ y_1(t)=\cos(t)</m> and <m>x_2(t)=\cos(t), \ y_2(t)=\sin(t)</m> 
        are the same paths.
        </p>
      </statement>
    </exercise>

    <exercise>
      <statement><!-- #4 -->
        <p>
         <m>\underline{\qquad\qquad\qquad}</m> The path represented by <m>x(t)=\sin(2t),\ y(t)=\cos(2t)</m>, where <m>0\leq t \leq2\pi</m>, 
         starts at <m>(0,1)</m> and moves in the clockwise direction twice around a circle centered at <m>(0,0)</m> with a radius  of 1.
        </p>
      </statement>
    </exercise>

    <exercise>
      <statement><!-- #5 -->
        <p>
         <m>\underline{\qquad\qquad\qquad}</m>Given <m>x(t)=t^2</m> and <m>y(t)=t^3-3t</m>, the slope of the tangent for any value of <m>t</m> is 
         <m>\displaystyle \frac{dy}{dx}=\frac{3t^2-3}{2t}</m>.
        </p>
      </statement>
    </exercise>

    <exercise>
      <statement><!-- #6 -->
        <p>
         <m>\underline{\qquad\qquad\qquad}</m>Given <m>x(t)=4\cos(t)</m> and <m>y(t)=3\sin(t)</m>, the slope of the tangent line at 
         <m>\displaystyle t=\frac{3\pi}{4}</m> is <m>\displaystyle\frac{4}{3}</m>.
        </p>
      </statement>
    </exercise>

    <exercise>
      <statement><!-- #7 -->
        <p>
         <m>\underline{\qquad\qquad\qquad}</m> The curve defined by  <m>x(t)=4\cos(t)</m>, <m>y(t)=3\sin(t)</m> has a horizontal tangent line 
         at <m>\displaystyle t=\frac{\pi}{2}</m>.
        </p>
      </statement>
    </exercise>

<exercise>
      <statement><!-- #8 -->
        <p>
         <m>\underline{\qquad\qquad\qquad}</m>The curve defined by  <m>x(t)=4\cos(t)</m>, <m>y(t)=3\sin(t)</m>, has a vertical tangent line at 
         <m>\displaystyle t=\frac{\pi}{2}</m>.
        </p>
      </statement>
    </exercise>

    </page>
    <page>
      <paragraphs>
        <title>Let Us Get Our Hands On</title>
      </paragraphs>
    <exercise number="1">
      <statement><!-- #1 -->
        <p>Complete the graph below so <m>f(x)</m> has the domain <m>[-8,7]</m>, <m>\displaystyle\lim_{x \rightarrow -4} f(x)=-2</m>, 
          and <m>\displaystyle\lim_{x \rightarrow 5^-} f(x)=9</m>. 
        <image source="M142_HOGU_session1_fig1.png" width="70%"/>
        </p>
      </statement>
    </exercise> 
    <exercise workspace="5 in" number="2">
      <statement><!-- #2 -->
        <p>Complete the tables below to estimate  <m>\displaystyle\lim_{t \rightarrow 0} \frac{|t-5|}{t}</m> numerically. 
          If the limit does not exist, state so and use limit notation to describe any infinite behavior. Round your answers to four decimal places (if necessary).
        <table>
          <title>Left-hand limit</title>
          <tabular halign="center">
            <row header="yes" bottom="minor" >
              <cell>Variable <m>t</m></cell>
              <cell>Variable <m>f(t)</m></cell>
            </row>
            <row>
              <cell><m>-0.1</m></cell>
              <cell></cell>
            </row>
            <row>
              <cell><m>-0.01</m></cell>
              <cell></cell>
            </row>
            <row>
              <cell><m>-0.001</m></cell>
              <cell></cell>
            </row>
            <row>
              <cell><m>-0.0001</m></cell>
              <cell></cell>
            </row>
          </tabular>
        </table>

        <table>
          <title>Right-hand limit</title>
          <tabular halign="center">
            <row header="yes" bottom="minor" >
              <cell>Variable <m>t</m></cell>
              <cell>Variable <m>f(t)</m></cell>
            </row>
            <row>
              <cell><m>-0.1</m></cell>
              <cell></cell>
            </row>
            <row>
              <cell><m>-0.01</m></cell>
              <cell></cell>
            </row>
            <row>
              <cell><m>-0.001</m></cell>
              <cell></cell>
            </row>
            <row>
              <cell><m>-0.0001</m></cell>
              <cell></cell>
            </row>
          </tabular>
        </table>
        </p>
      </statement>
    </exercise>
  </page>
  <page>
    <exercise workspace="1 in" number="3">
      <statement><!-- #3 -->
        <p> Set up a table to estimate <m>\displaystyle \lim_{x \rightarrow -2} \frac{x^2-x-6}{(x+2)(x+7)}</m> numerically. 
          When creating your table, show at least three <m>x</m>-values approaching <m>-2</m> from each side and their corresponding function values in the table. 
          If the limit does not exist, state so and use limit notation to describe any infinite behavior. 
          Round your answers to four decimal places (if necessary).  
        </p>
      </statement>
    </exercise> 
    <exercise workspace="1 in" number="4">
      <statement><!-- #4 -->
        <p> Given the graph of <m>f(x)</m> below and <m>g(x)=\frac{10x-30}{x^2-x-6}</m>, 
          find <m>\displaystyle\lim_{x \rightarrow 3} \left( \frac{f(x)+5x}{2}+\sqrt{g(x)+14} \right)</m>. 
        </p>
      </statement>
    </exercise> 
  </page>
  <page>
    <exercise workspace="1 in" number="5">
      <statement><!-- #5 -->
        <p>Given <m>f(x) = \{ 5^{4x-3} \text{ if } x \leq -5, \frac{x^2-x}{x^2+2x} \text{ if } x > -5 \}</m>
        </p>
      </statement>
    </exercise> 
  </page>
  <page>
    <exercise workspace="1 in" number="6">
      <statement><!-- #6 -->
        <p> Find the following limits algebraically. If the limit does not exist, state so and use limit notation to describe any infinite behavior. 
          Round your answers to four decimal places (if necessary). 
        </p>
      </statement>
    </exercise> 
    <exercise workspace="1 in" number="7">
      <statement><!-- #7 -->
        <p> For each graph below, find the indicated limit.  
        </p>
      </statement>
    </exercise> 
    <exercise workspace="1 in" number="8">
      <statement><!-- #8 -->
        <p> Jenn is trying to find <m>\displaystyle\lim_{x \rightarrow \infty} f(x)</m> given  <m>f(x) = \frac{12+4x^7+x}{-19x^6+2x^2-5x^7}</m>. </p>
      </statement>
    </exercise> 
  </page>
  <page>
    <paragraphs>
        <title>Now Grades Go Up</title>
      </paragraphs>
 <exercise workspace ="1 in" number="1">
  <statement><!-- #1 -->
    <p>
      The mathematical notation <m>\displaystyle\lim \limits_{x \rightarrow 5} f(x)</m> means <m>\underline{ \qquad\qquad}</m>
        <ol marker="(a)">
          <li> <p>we need to find the value of the function  at <m>x=5</m>.</p> </li>
          <li> <p> we need to investigate the <m>y</m>-values of <m>f(x)</m> as <m>x</m> gets very near <m>x=5</m> from both the left and right sides of <m>x=5</m>, 
            but not necessarily at <m>x=5</m>.</p> </li>
          <li> <p>we need to find the horizontal asymptotes. </p> </li>
          <li> <p> we need to find the instantaneous rate of change.</p> </li>
          <li> <p> we need to investigate the <m>y</m>-values as we approach <m>x=5</m> only on the right side.</p> </li>
        </ol>
    </p>
  </statement>
 </exercise>
 <exercise workspace ="1 in" number="2">
  <statement><!-- #2 -->
    <p>
      Find <m>\displaystyle\lim_{x\rightarrow 2^-} \frac{3x^2}{x^2-4}</m>. If the limit does not exist, but has infinite behavior, use limit notation to 
          describe the infinite behavior of the function as <m>x \longrightarrow 2^-</m>.
        <ol marker="(a)">
          <li> <p> <m>\displaystyle {\lim_{x\rightarrow 2^-} \frac{3x^2}{x^2-4}}=3</m></p> </li>
          <li> <p> <m>\displaystyle{\lim_{x\rightarrow 2^-} \frac{3x^2}{x^2-4}}=-\infty</m></p> </li>
          <li> <p> <m>\displaystyle{\lim_{x\rightarrow 2^-} \frac{3x^2}{x^2-4}}</m> DNE, 
            but has infinite behavior that can be described as <m>\displaystyle{\lim_{x \rightarrow 2^-} f(x) \rightarrow -\infty}</m>. </p> </li>
          <li> <p><m>\displaystyle{\lim_{x\rightarrow 2^-} \frac{3x^2}{x^2-4}}</m> DNE, 
            but has infinite behavior that can be described as <m>\displaystyle{\lim_{x \rightarrow 2^-} f(x) \rightarrow \infty}</m>. </p> </li>
          <li> <p> <m>\displaystyle {\lim_{x\rightarrow 2^-} \frac{3x^2}{x^2-4}}=0</m> </p> </li>
        </ol>
    </p>
  </statement>
 </exercise>
 <exercise workspace ="1 in" number="3">
  <statement><!-- #3 -->
    <p>
      Find <m>\displaystyle\lim \limits_{x \rightarrow 7} \frac{x^2-8x+7}{x-7}</m>.
        <ol marker="(a)">
          <li> <p> <m>0</m> </p> </li>
          <li> <p> DNE </p> </li>
          <li> <p> <m>6</m>  </p> </li>
          <li> <p> <m>8</m> </p> </li>
          <li> <p> None of these. </p> </li>
        </ol>
    </p>
  </statement>
 </exercise>
</page>
</worksheet>

